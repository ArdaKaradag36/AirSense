# Bu dosyayi kopyalayip backend/.env olarak kaydedin ve gercek degerleri doldurun.
# backend/.env .gitignore ile korunur — ASLA commit etmeyin.

# Demo (donanim yok): backend/demo.env.example dosyasini .env olarak kopyalayin.

# -----------------------------------------------------------------------
# SUPABASE — Dashboard -> Project Settings -> API
# -----------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# service_role anahtari (anon DEGIL) — sadece backend sunucusunda kullanilir; RLS'i bypass eder.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------
# CIHAZ API SECRET — ESP32'nin HTTP POST'larini dogrulamak icin kullanilir.
# Uretmek icin: openssl rand -hex 32
# Bu deger firmware/secrets.h icindeki DEVICE_API_KEY ile AYNI olmali.
# -----------------------------------------------------------------------
AIRSENSE_API_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS

# -----------------------------------------------------------------------
# CORS — Virgülle ayrilmis izin verilen originler.
# Prod: HTTPS domain'leriniz.  Dev: localhost portlari.
# Bos birakilirsa yalnizca localhost:8081 ve localhost:19006'ya izin verilir.
# -----------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# -----------------------------------------------------------------------
# USB BRIDGE (opsiyonel) — usb_bridge.py kullaniyorsaniz
# -----------------------------------------------------------------------
# USB_BRIDGE_PORT=/dev/ttyUSB0     # bos birakilirsa /dev/ttyUSB*, /dev/ttyACM* otomatik taranir
# USB_BRIDGE_BAUD=115200
# USB_BRIDGE_API_URL=http://127.0.0.1:8000/api/v1/data
