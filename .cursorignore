# -----------------------------------------------------------------------------
# AirSense — Cursor index exclusions (smaller context, fewer tokens)
# Expo / React Native / Python / PlatformIO. Mirrors .gitignore where useful.
# -----------------------------------------------------------------------------

# Dependencies
**/node_modules/
bower_components/

# Python
**/.venv/
**/venv/
.venv/
__pycache__/
*.py[cod]
*$py.class
.Python

# Expo / Metro
.expo/
.expo-shared/
**/.expo/
web-build/
.metro-health-check*

# React Native native outputs
**/android/build/
**/android/app/build/
**/android/.gradle/
**/ios/build/
**/ios/Pods/
**/DerivedData/

# PlatformIO
.pio/
**/.pio/

# Build / cache
dist/
build/
out/
.next/
.turbo/
.parcel-cache/
coverage/
bin/
obj/
*.tsbuildinfo
.cache/

# Secrets and logs
.env
.env.*
!.env.example
!**/.env.example
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Lockfiles (very long; delete these rows if you want versions in context)
package-lock.json
**/package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
.history/

# Media and binaries (do not use *.json — it hides tsconfig, app.json, etc.)
**/*.png
**/*.jpg
**/*.jpeg
**/*.gif
**/*.webp
**/*.ico
**/*.svg
**/*.mp4
**/*.webm
**/*.wav
**/*.mp3
**/*.pdf
**/*.zip
**/*.tar
**/*.tar.gz
**/*.tgz
**/*.7z
*.map

assets/fonts/
assets/images/
public/img/
**/assets/fonts/
**/assets/images/

*.csv
*.parquet

# BPMN XML is verbose; remove if you want diagrams indexed
**/*.bpmn

models/
*.bin
*.pt
*.onnx
*.safetensors
*.h5
*.pkl
