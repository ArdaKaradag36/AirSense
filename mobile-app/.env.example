# -----------------------------------------------------------------------
# HOCA DEMO (donanim yok) — Supabase gerekmez; veri FastAPI SQLite demo API'den okunur
# -----------------------------------------------------------------------
# EXPO_PUBLIC_DEMO_MODE=true
# EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:8000

# Opsiyonel — yalnızca push token kaydı için (sensör verisi Supabase'den okunur).
# Fiziksel iPhone: bilgisayarının Wi‑Fi IP’si (127.0.0.1 telefonda çalışmaz).
# Örnek: hostname -I | awk '{print $1}'
EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:8000

# İsteğe bağlı (nadiren): /api/v1 tam kök — apiService artık bunu kullanmıyor; sadece BASE_URL için yeterli:
# EXPO_PUBLIC_API_BASE_URL yeterli.

EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
# Opsiyonel: sifre sifirlama mailindeki redirect (dev build / tek sema). Bos = Expo Go exp://...
# EXPO_PUBLIC_PASSWORD_RESET_REDIRECT=mobileapp://reset-password
